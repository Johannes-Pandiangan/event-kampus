{
  "version": 2,
  "builds": [
    {
      "src": "event-kampus/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "event-kampus-backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "event-kampus-backend/server.js"
    },
    {
      "src": "/(.*\\.[^/]+)$",
      "dest": "event-kampus/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "event-kampus/dist/index.html"
    }
  ]
}
